# Copia questo file in .env.test (già in .gitignore, non verrà mai committato) per
# eseguire i test di integrazione contro i veri account Claude/Copilot.
# Non incollare MAI questi valori in chat, issue, log condivisi o altrove.
#
# Uso: npm test (Node carica .env.test automaticamente se presente, vedi package.json)

# Cookie di sessione Claude (vedi RESEARCH.md v3 §1). Puoi ottenerlo completando un
# login reale — es. tramite il flusso "Connetti" dell'app — e leggendo il cookie
# sessionKey della sessione risultante.
HYPERMILER_TEST_CLAUDE_SESSION_KEY=

# Opzionale: se non impostato, il test risolve automaticamente la prima organizzazione.
HYPERMILER_TEST_CLAUDE_ORG_ID=

# Fine-grained Personal Access Token GitHub con permesso "Plan" (read).
HYPERMILER_TEST_COPILOT_TOKEN=

# 'personal' (default) o 'organization' per testare anche il percorso best-effort
# del seat aziendale (vedi RESEARCH.md v3 §2.2).
HYPERMILER_TEST_COPILOT_SCOPE=personal
