{
  "name": "ia-hypermiler",
  "version": "0.1.0",
  "description": "Widget desktop che monitora il consumo di token AI (Claude e GitHub Copilot) e calcola un budget giornaliero ottimale.",
  "main": "dist/main.js",
  "type": "commonjs",
  "scripts": {
    "build:main": "tsc -p tsconfig.json",
    "build:renderer": "tsc -p tsconfig.renderer.json",
    "copy-assets": "node scripts/copy-assets.js",
    "build": "npm run build:main && npm run build:renderer && npm run copy-assets",
    "start": "npm run build && electron .",
    "test": "npm run build && node --env-file-if-exists=.env.test --test dist",
    "package": "npm run build && electron-builder"
  },
  "author": "",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "date-fns": "^3.6.0",
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "typescript": "^5.6.0"
  },
  "build": {
    "appId": "com.delbrocco.ia-hypermiler",
    "files": [
      "dist/**/*"
    ],
    "mac": { "target": "dmg" },
    "win": { "target": "nsis" },
    "linux": { "target": "AppImage" }
  }
}
