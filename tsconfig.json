{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true,
    "types": ["node"]
  },
  "include": [
    "*.ts",
    "store/**/*.ts",
    "services/**/*.ts",
    "agents/**/*.ts",
    "main/**/*.ts",
    "types/**/*.ts",
    "tests/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "renderer"]
}
